# Email & Communication Automation Agent Configuration

# Application
APP_NAME="Email Communication Agent"
APP_VERSION="1.0.0"
ENV="development"
DEBUG=true
LOG_LEVEL="INFO"

# Server
HOST="0.0.0.0"
PORT=8000

# Ollama Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# Gmail API (from Google Cloud Console)
GMAIL_CLIENT_ID="your-gmail-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REDIRECT_URI="http://localhost:8000/auth/gmail/callback"

# Microsoft Outlook/Graph API (from Azure Portal)
OUTLOOK_CLIENT_ID="your-outlook-client-id"
OUTLOOK_CLIENT_SECRET="your-outlook-client-secret"
OUTLOOK_TENANT_ID="common"

# Slack Integration (optional)
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"

# Microsoft Teams (optional)
TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/your-webhook-url"

# PostgreSQL Database
DATABASE_URL="postgresql://user:password@localhost:5432/email_agent"

# Redis Cache
REDIS_URL="redis://localhost:6379/0"

# Celery Task Queue
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# ChromaDB Vector Store
CHROMA_PERSIST_DIRECTORY="./data/chroma"
